blueprint:
  name: FrigateVision - Multi-Camera Priority
  description: >
    Watches multiple Frigate cameras with a configurable priority order.
    When events fire across cameras within a short collection window, the
    highest-priority camera wins LLM analysis. Lower-priority simultaneous
    detections are mentioned in the notification but not analyzed separately.
    Supports reverse-proxied HA and Frigate URLs, LLM clip analysis,
    Android/iOS, cooldown, sublabels, and all original FrigateVision features.
  domain: automation
  input:

    cameras:
      name: Frigate Camera Entities (Priority Order)
      description: >
        Select all cameras to monitor. Order matters - cameras listed first
        have higher priority. If multiple cameras detect something within the
        collection window, the first camera in this list wins LLM analysis.
      selector:
        entity:
          domain: [camera]
          multiple: true

    labels:
      name: Labels to Notify On
      description: Leave empty to match all labels.
      default: [person]
      selector:
        select:
          multiple: true
          options:
            - person
            - dog
            - cat
            - car
            - package
            - bicycle
            - face
          sort: false
          custom_value: false

    helper:
      name: Helper (Input Boolean)
      description: Input Boolean used to prevent concurrent LLM Vision runs.
      selector:
        entity:
          domain: [input_boolean]
          multiple: false

    cooldown:
      name: Cooldown
      description: Minimum time between notifications (per camera group).
      selector:
        duration:
          enable_day: true

    collection_window:
      name: Priority Collection Window (seconds)
      description: >
        How long to wait after the first event fires before picking the
        highest-priority camera. Events from multiple cameras within this
        window are compared. 3-8 seconds is a good starting point.
      default: 5
      selector:
        number:
          min: 1
          max: 30
          step: 1
          unit_of_measurement: seconds
          mode: slider

    notify_device:
      name: Mobile Device(s)
      description: Phone or tablet(s) with the HA app to receive notifications.
      selector:
        device:
          integration: mobile_app
          multiple: true

    notification_customization:
      name: Notification Customization
      icon: mdi:message-alert
      collapsed: true
      input:
        ios_live_view:
          name: iOS Notification
          description: Enable for iOS enhanced notification support.
          default: false
          selector:
            boolean: {}

        append:
          name: Append Camera
          description: Add "Camera" to the end of camera names in notifications.
          default: false
          selector:
            boolean: {}

        expand:
          name: Expand Cam to Camera
          default: false
          selector:
            boolean: {}

        dashboard:
          name: Event Summary Dashboard URI
          description: URI opened when "View Summary" action is tapped.
          default:
          selector:
            text: {}

    llmvision_tweaks:
      name: LLMVision Tweaks
      icon: mdi:brain
      collapsed: true
      input:
        generate_title:
          name: Generate Event Title
          default: true
          selector:
            boolean: {}

        include_filename:
          name: Include Filenames
          default: false
          selector:
            boolean: {}

        expose_images:
          name: Expose Images
          description: Save analyzed frames to /www/llmvision.
          default: true
          selector:
            boolean: {}

        provider:
          name: Provider
          selector:
            config_entry:
              integration: llmvision

        model:
          name: Model
          default: gemini-2.0-flash
          selector:
            text:
              multiline: false
              multiple: false

        prompt:
          name: LLMVision Prompt
          default: >
            Summarize the observed events using clear, neutral third-person language.
            Use timestamps to ensure the summary follows the correct chronological order.
            Focus on moving subjects such as people, vehicles, animals, packages,
            equipment, or other active elements. Ignore static background objects
            unless directly interacted with. Include stationary vehicles only if they
            are clearly identifiable as delivery or emergency vehicles, mentioning any
            visible company names or uniform details. Describe activity relevant to the
            general monitored area without referencing camera angles, timestamps, or
            observers. Present the events as if witnessed in real time, avoiding
            frame-by-frame descriptions or introductory phrases. Summarize naturally
            in a single, cohesive narrative, keeping it concise and suitable for brief
            notifications. When context strongly suggests a likely outcome, describe it
            confidently. Do not mention the absence of activity or objects, nor conclude
            with statements about what was or wasn't observed.
          selector:
            text:
              multiline: true
              multiple: false

        max_tokens:
          name: Maximum Tokens
          default: 20
          selector:
            number:
              min: 1
              max: 100
              mode: slider
              step: 1

        temperature:
          name: Temperature
          default: 0.1
          selector:
            number:
              min: 0.1
              max: 1.0
              step: 0.1
              mode: slider

        max_frames:
          name: Total Frames
          default: 3
          selector:
            number:
              min: 1
              max: 60
              mode: slider
              step: 1

        frigate_retry_attempts:
          name: Retry Attempts
          selector:
            number:
              min: 1
              max: 20
              mode: slider
              step: 1

        frigate_retry_time:
          name: Retry Timing
          selector:
            duration: {}

        target_width:
          name: Target Width
          default: 1920
          selector:
            number:
              min: 480
              max: 3840
              mode: slider
              step: 20

    advanced_options:
      name: Advanced Options
      icon: mdi:cog
      collapsed: true
      input:

        sublabel:
          name: Include Sublabels
          default: true
          selector:
            boolean: {}

        base_url:
          name: External Home Assistant URL
          description: >
            Public-facing URL for Home Assistant. Used to build clip, snapshot,
            and action links in notifications. If behind a reverse proxy with no
            port (e.g. https://ha.yourdomain.com) enter just the domain and enable
            "HA is Reverse Proxied" below. If connecting directly include the port
            (e.g. https://your.ddns:8123).
          default: https://your.ddns:8123
          selector:
            text: {}

        ha_reverse_proxied:
          name: Home Assistant is Reverse Proxied
          description: >
            Enable when HA is accessible without a port number via a reverse proxy.
            ON = :8123 is never appended to any HA URL.
            OFF = :8123 is always appended (direct connection).
          default: false
          selector:
            boolean: {}

        local_url:
          name: Internal Home Assistant URL
          description: >
            Local URL used by LLM Vision to fetch clips on your internal network.
            If HA is also locally proxied without a port enter just the local
            hostname (e.g. http://ha.local) and enable the toggle below.
            If connecting directly include the port (e.g. http://192.168.1.10:8123).
          default: http://192.168.250.1:8123
          selector:
            text: {}

        local_ha_reverse_proxied:
          name: Local HA Access is Also Reverse Proxied
          description: >
            Enable if your internal LLM Vision fetches go through a local reverse
            proxy with no port. ON = :8123 not appended to local_url.
            OFF = :8123 always appended to local_url.
          default: false
          selector:
            boolean: {}

        frigate_url:
          name: External Frigate URL (optional)
          description: >
            Public-facing URL for the Frigate UI, used for the "Open Frigate"
            action button. Set this when Frigate has its own subdomain
            (e.g. https://frigate.yourdomain.com) or subpath. Leave blank to
            auto-derive from the HA base_url above.
          default: ""
          selector:
            text: {}

        frigate_reverse_proxied:
          name: Frigate is Reverse Proxied
          description: >
            Enable when Frigate is accessible without a port via a reverse proxy.
            ON = :8971 never appended to Frigate URLs.
            OFF = :8971 appended to base_url automatically when frigate_url is blank.
          default: false
          selector:
            boolean: {}

        debug:
          name: Debugging
          default: false
          selector:
            boolean: {}

        notification_timeout:
          name: Notification Timeout (minutes)
          default: 10
          selector:
            number:
              min: 1
              max: 120
              step: 1
              unit_of_measurement: minutes
              mode: slider

  source_url: https://github.com/joshuaabarker97/Frigate_notifications/blob/main/frigate_notifications.yaml

# ---------------------------------------------------------------------------
# Trigger: fires on any Frigate event. Label and camera filtering happens
# in the condition block. Single mode ensures only one run at a time across
# all cameras, so a busy camera can't queue-bomb the automation.
# ---------------------------------------------------------------------------
trigger:
  - trigger: mqtt
    topic: frigate/events
    id: frigate-event

# ---------------------------------------------------------------------------
# Actions
# ---------------------------------------------------------------------------
actions:

  # ── Step 1: resolve all inputs into variables ───────────────────────────
  - variables:
      input_cameras: !input cameras
      input_labels: !input labels
      input_collection_window: !input collection_window
      input_append: !input append
      input_expand: !input expand
      input_dashboard: !input dashboard
      input_provider: !input provider
      input_frigate_retry_attempts: !input frigate_retry_attempts
      input_frigate_retry_time: !input frigate_retry_time
      input_frigate_retry_seconds: >
        {% set d = input_frigate_retry_time %}
        {{ (d.hours | default(0)) * 3600 + (d.minutes | default(0)) * 60 + (d.seconds | default(0)) }}
      input_max_frames: !input max_frames
      input_notification_timeout: !input notification_timeout
      input_ios_live_view: !input ios_live_view
      input_include_filename: !input include_filename
      input_generate_title: !input generate_title
      input_expose_images: !input expose_images
      input_model: !input model
      input_target_width: !input target_width
      input_max_tokens: !input max_tokens
      input_temperature: !input temperature
      input_prompt: !input prompt
      input_sublabel: !input sublabel
      input_cooldown: !input cooldown
      input_helper: !input helper
      input_debug: !input debug
      input_base_url: !input base_url
      input_ha_reverse_proxied: !input ha_reverse_proxied
      input_local_url: !input local_url
      input_local_ha_reverse_proxied: !input local_ha_reverse_proxied
      input_frigate_url: !input frigate_url
      input_frigate_reverse_proxied: !input frigate_reverse_proxied
      raw_device: !input notify_device

      triggered_camera: >
        {{ trigger.payload_json['after']['camera'] | lower | replace('-', '_') }}
      camera_priority_list: >
        {{ input_cameras | map('replace', 'camera.', '') | list }}
      camera_is_watched: >
        {{ triggered_camera in camera_priority_list }}
      object: "{{ trigger.payload_json['after']['label'] }}"
      labels: "{{ input_labels | list | lower }}"

  # ── Step 2: bail if camera not watched or label not matched ─────────────
  - condition: template
    value_template: >
      {{ camera_is_watched and (not labels | length or object in labels) }}

  # ── Step 3: seed competition list with the triggering event ─────────────
  - variables:
      competing_events: >
        {{ [{'camera': triggered_camera,
             'id': trigger.payload_json['after']['id'],
             'label': trigger.payload_json['after']['label']}] }}

  # ── Step 4: wait for competing events within the collection window ───────
  - wait_for_trigger:
      - trigger: mqtt
        topic: frigate/events
    timeout:
      seconds: "{{ input_collection_window }}"
    continue_on_timeout: true

  # ── Step 5: pick the winner and build all resolved URLs ─────────────────
  - variables:
      extra_camera: >
        {% if wait.trigger %}
          {{ wait.trigger.payload_json['after']['camera'] | lower | replace('-', '_') }}
        {% else %}''{% endif %}
      extra_label: >
        {% if wait.trigger %}{{ wait.trigger.payload_json['after']['label'] }}{% else %}''{% endif %}
      extra_id: >
        {% if wait.trigger %}{{ wait.trigger.payload_json['after']['id'] }}{% else %}''{% endif %}

      all_events: >
        {% set base = competing_events %}
        {% if extra_camera and extra_camera in camera_priority_list
              and (not labels | length or extra_label in labels)
              and extra_camera != triggered_camera %}
          {{ base + [{'camera': extra_camera, 'id': extra_id, 'label': extra_label}] }}
        {% else %}
          {{ base }}
        {% endif %}

      winning_event: >
        {% set ns = namespace(best=none, best_rank=999) %}
        {% for ev in all_events %}
          {% set rank = camera_priority_list.index(ev.camera) if ev.camera in camera_priority_list else 999 %}
          {% if rank < ns.best_rank %}
            {% set ns.best = ev %}
            {% set ns.best_rank = rank %}
          {% endif %}
        {% endfor %}
        {{ ns.best }}

      secondary_cameras: >
        {% set winner = winning_event.camera %}
        {{ all_events | selectattr('camera', '!=', winner) | map(attribute='camera') | list }}

      camera: "{{ winning_event.camera }}"
      id: "{{ winning_event.id }}"
      object: "{{ winning_event.label }}"
      label: "{{ winning_event.label | title }}"

      # ── URL resolution ──────────────────────────────────────────────────
      # Strip trailing slashes from all raw inputs
      _base: "{{ input_base_url.rstrip('/') }}"
      _local: "{{ input_local_url.rstrip('/') }}"
      _frigate_raw: "{{ input_frigate_url.rstrip('/') }}"

      # External HA: append :8123 only when NOT reverse proxied
      base_url: >
        {% if input_ha_reverse_proxied %}{{ _base }}
        {% else %}{{ _base ~ ':8123' }}{% endif %}

      # Internal HA: append :8123 only when NOT locally proxied
      local_url: >
        {% if input_local_ha_reverse_proxied %}{{ _local }}
        {% else %}{{ _local ~ ':8123' }}{% endif %}

      # Frigate UI URL resolution:
      #   Priority 1 - explicit frigate_url provided: use it as-is
      #   Priority 2 - no explicit url + reverse proxied: use HA base (no port)
      #   Priority 3 - no explicit url + not proxied: append :8971 to HA base input
      frigate_base_url: >
        {% if _frigate_raw %}{{ _frigate_raw }}
        {% elif input_frigate_reverse_proxied %}{{ _base }}
        {% else %}{{ _base ~ ':8971' }}{% endif %}

      # Final convenience URLs used throughout the rest of the automation
      local_clip_url: "{{ local_url }}/api/frigate/notifications/{{ id }}/{{ camera }}/clip.mp4"
      clip_url: "{{ base_url }}/api/frigate/notifications/{{ id }}/{{ camera }}/clip.mp4"
      snapshot_url: "{{ base_url }}/api/frigate/notifications/{{ id }}/snapshot.jpg"
      frigate_review_url: "{{ frigate_base_url }}/review"

      camera_name: >
        {% set name = camera | replace('_', ' ') | title %}
        {% if input_expand %}
          {% set name = name | regex_replace('(?i)\\bcam\\b', 'Camera') %}
        {% endif %}
        {{ name ~ (' Camera' if input_append else '') }}

      cooldown: >
        {{ '%02d:%02d:%02d' | format(
            input_cooldown.hours + (input_cooldown.days * 24),
            input_cooldown.minutes,
            input_cooldown.seconds) }}

      icon: >
        mdi:{{ 'account-outline' if label == 'Person'
              else 'dog' if label == 'Dog'
              else 'cat' if label == 'Cat'
              else 'car' if label == 'Car'
              else 'home-assistant' }}

      secondary_note: >
        {% if secondary_cameras | length %}
          Also detected on: {{ secondary_cameras | map('replace', '_', ' ') | map('title') | join(', ') }}.
        {% else %}''{% endif %}

      title: ''
      message: >
        A {{ label }} was detected on the {{ camera_name }}.
        {{ secondary_note }}

      alert_once: true
      update_thumbnail: true
      sub_label: ''

  # ── Step 6: send initial notification ──────────────────────────────────
  - repeat:
      for_each: "{{ raw_device }}"
      sequence:
        - variables:
            input_notify_device: >
              {{ 'notify.mobile_app_' ~ (device_attr(repeat.item, 'name')
                  | lower | replace(' ', '_') | replace("'", '') | replace('`', '') | replace('"', '') | trim) }}
        - service: "{{ input_notify_device }}"
          data:
            title: "{{ title }}"
            message: "{{ message }}"
            data:
              channel: "{{ camera_name }} Notifications"
              timeout: "{{ input_notification_timeout * 60 | int }}"
              tag: "{{ id }}"
              group: "{{ camera_name }}"
              notification_icon: "{{ icon }}"
              data:
                ttl: 0
                priority: high
              attachment:
                url: /api/frigate/notifications/{{ id }}/thumbnail.jpg
              image: /api/frigate/notifications/{{ id }}/thumbnail.jpg?format=android
              clickAction: "{{ clip_url }}"
              push:
                interruption-level: active
              alert_once: "{{ alert_once }}"
              actions:
                - action: URI
                  title: View Clip
                  uri: "{{ clip_url }}"
                - action: URI
                  title: View Summary
                  uri: "{{ input_dashboard }}"
                - action: URI
                  title: Open Frigate
                  uri: "{{ frigate_review_url }}"

  # ── Step 7: event update loop (snapshot/sublabel changes) ───────────────
  - repeat:
      sequence:
        - wait_for_trigger:
            - trigger: mqtt
              topic: frigate/events
              payload: "{{ id }}"
              value_template: "{{ value_json['after']['id'] }}"
          timeout: "{{ input_cooldown }}"
          continue_on_timeout: true
        - variables:
            event: "{{ wait.trigger.payload_json }}"
            new_snapshot: >
              {{ update_thumbnail and
                 event['before']['snapshot_time'] != event['after']['snapshot_time'] }}
            sub_label: "{{ event['after']['sub_label'] }}"
            sub_label_changed: "{{ sub_label != event['before']['sub_label'] }}"
            title: >
              {% if sub_label %}
                {% set ns = namespace(names=[]) %}
                {% for i in range(0, sub_label | length, 2) %}
                  {% set ns.names = ns.names + [sub_label[i]] %}
                {% endfor %}
                {{ ns.names[:-1] | join(', ') ~ (', and ' if ns.names | length > 2 else ' and ') ~ ns.names[-1]
                   if ns.names | length > 1 else ns.names[0] }}
                {% if ns.names | length > 1 %}were{% else %}was{% endif %}
                detected on the {{ camera_name }}.
              {% else %}
                A {{ label }} was detected on the {{ camera_name }}.
              {% endif %}
            message: >
              {% if sub_label %}{% else %}
                A {{ label }} was detected on the {{ camera_name }}.
                {{ secondary_note }}
              {% endif %}
        - alias: Notify on snapshot update or sublabel change
          choose:
            - conditions:
                - condition: template
                  value_template: "{{ new_snapshot or sub_label_changed }}"
              sequence:
                - repeat:
                    for_each: "{{ raw_device }}"
                    sequence:
                      - variables:
                          input_notify_device: >
                            {{ 'notify.mobile_app_' ~ (device_attr(repeat.item, 'name')
                                | lower | replace(' ', '_') | replace("'", '') | replace('`', '') | replace('"', '') | trim) }}
                      - service: "{{ input_notify_device }}"
                        data:
                          title: "{{ title }}"
                          message: "{{ message }}"
                          data:
                            channel: "{{ camera_name }} Notifications"
                            timeout: "{{ input_notification_timeout * 60 | int }}"
                            tag: "{{ id }}"
                            group: "{{ camera_name }}"
                            notification_icon: "{{ icon }}"
                            data:
                              ttl: 0
                              priority: high
                            attachment:
                              url: /api/frigate/notifications/{{ id }}/thumbnail.jpg
                            image: /api/frigate/notifications/{{ id }}/thumbnail.jpg?format=android
                            clickAction: "{{ clip_url }}"
                            push:
                              interruption-level: active
                            alert_once: "{{ alert_once }}"
                            actions:
                              - action: URI
                                title: View Clip
                                uri: "{{ clip_url }}"
                              - action: URI
                                title: View Summary
                                uri: "{{ input_dashboard }}"
                              - action: URI
                                title: Open Frigate
                                uri: "{{ frigate_review_url }}"
      until:
        - condition: template
          value_template: >
            {{ not wait.trigger or wait.trigger.payload_json['type'] == 'end' }}

  # ── Step 8: wait 30s for clip to be ready, then run LLM Vision ──────────
  - delay: 00:00:30

  - alias: Wait if LLM Vision already running
    if:
      - condition: state
        entity_id: !input helper
        state: 'on'
    then:
      - wait_for_trigger:
          - platform: state
            entity_id: !input helper
            from: 'on'
            to: 'off'
        timeout:
          minutes: 3
        continue_on_timeout: false

  - action: input_boolean.turn_on
    target:
      entity_id: !input helper

  - alias: "LLM Vision: Analyze Winning Camera Clip"
    action: llmvision.video_analyzer
    data:
      remember: true
      model: "{{ input_model }}"
      provider: "{{ input_provider }}"
      frigate_retry_attempts: "{{ input_frigate_retry_attempts }}"
      frigate_retry_seconds: "{{ input_frigate_retry_seconds }}"
      max_frames: "{{ input_max_frames }}"
      include_filename: "{{ input_include_filename }}"
      target_width: "{{ input_target_width }}"
      max_tokens: "{{ input_max_tokens }}"
      temperature: "{{ input_temperature }}"
      generate_title: "{{ input_generate_title }}"
      expose_images: "{{ input_expose_images }}"
      video_file: "{{ local_clip_url }}"
      message: >
        {% if input_sublabel and sub_label %}
          You are analyzing frames from a security video showing that {{ title | string }}.
        {% endif %}
        {% if secondary_cameras | length %}
          Note: simultaneous activity was also detected on
          {{ secondary_cameras | map('replace', '_', ' ') | map('title') | join(' and ') }}.
          Focus your analysis on the primary camera feed only.
        {% endif %}
        {{ input_prompt }}
    response_variable: response
    enabled: true

  - action: input_boolean.turn_off
    target:
      entity_id: !input helper

  - variables:
      message: "{{ response.response_text }}"

  # ── Step 9: send final LLM summary notification ─────────────────────────
  - repeat:
      for_each: "{{ raw_device }}"
      sequence:
        - variables:
            input_notify_device: >
              {{ 'notify.mobile_app_' ~ (device_attr(repeat.item, 'name')
                  | lower | replace(' ', '_') | replace("'", '') | replace('`', '') | replace('"', '') | trim) }}
        - service: "{{ input_notify_device }}"
          data:
            title: "{{ title }}"
            message: "{{ message }}"
            data:
              channel: "{{ camera }}_notifications"
              timeout: "{{ input_notification_timeout * 60 | int }}"
              tag: "{{ id }}"
              group: "{{ camera_name }}"
              notification_icon: "{{ icon }}"
              data:
                ttl: 0
                priority: high
              attachment:
                url: >
                  {% if input_ios_live_view %}
                    {{ clip_url }}?sign=true
                  {% else %}
                    /api/frigate/notifications/{{ id }}/thumbnail.jpg
                  {% endif %}
              image: /api/frigate/notifications/{{ id }}/thumbnail.jpg?format=android
              clickAction: "{{ clip_url }}"
              push:
                interruption-level: active
              alert_once: "{{ alert_once }}"
              actions:
                - action: URI
                  title: View Clip
                  uri: "{{ clip_url }}"
                - action: URI
                  title: View Summary
                  uri: "{{ input_dashboard }}"
                - action: URI
                  title: Open Frigate
                  uri: "{{ frigate_review_url }}"

  # ── Step 10: cooldown before this automation can fire again ─────────────
  - delay: "{{ input_cooldown }}"

mode: single
